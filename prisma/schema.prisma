generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model SentContact {
  email     String   @id @map("email")
  name      String   @map("name")
  sentCount Int      @default(1) @map("sent_count")
  lastSent  DateTime @map("last_sent")

  @@map("sent_contacts")
}

model Snoozed {
  uid         Int      @map("uid")
  folder      String   @default("inbox") @map("folder")
  snoozeUntil DateTime @map("snooze_until")

  @@id([uid, folder])
  @@map("snoozed")
}

model RecentSearch {
  id         Int      @id @default(autoincrement())
  query      String   @unique @map("query")
  searchedAt DateTime @map("searched_at")

  @@map("recent_searches")
}

model Signature {
  id        Int    @id @default(autoincrement())
  userEmail String @default("") @map("user_email")
  name      String @default("Default") @map("name")
  html      String @default("") @db.MediumText @map("html")
  isDefault Int    @default(0) @map("is_default")

  @@map("signatures")
}

model Session {
  token      String   @id @map("token")
  email      String   @map("email")
  imapUser   String   @default("") @map("imap_user")
  imapPass   String   @default("") @db.Text @map("imap_pass")
  imapServer String   @default("") @map("imap_server")
  imapPort   Int      @default(993) @map("imap_port")
  createdAt  DateTime @map("created_at")
  expiresAt  DateTime @map("expires_at")

  @@map("sessions")
}

model UserSettings {
  userEmail   String  @id @map("user_email")
  readingPane Boolean @default(false) @map("reading_pane")

  @@map("user_settings")
}

model LoginAudit {
  id         Int      @id @default(autoincrement())
  email      String   @default("") @map("email")
  ip         String   @default("") @map("ip")
  userAgent  String   @default("") @db.Text @map("user_agent")
  domain     String   @default("") @map("domain")
  imapServer String   @default("") @map("imap_server")
  success    Boolean  @map("success")
  blocked    Boolean  @default(false) @map("blocked")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([ip])
  @@index([createdAt])
  @@map("login_audits")
}

model ImapServer {
  id        Int      @id @default(autoincrement())
  label     String   @map("label")
  host      String   @map("host")
  port      Int      @default(993) @map("port")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("imap_servers")
}
